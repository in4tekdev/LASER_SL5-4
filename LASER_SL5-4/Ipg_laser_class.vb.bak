Public Class Laser_EventArgs
    Inherits System.EventArgs

    Public Laser_stat As laser_status_struct

    Public Sub New(argu As laser_status_struct)
        MyBase.New
        Laser_stat.msg_target = argu.msg_target
        Laser_stat.msg_str = argu.msg_str
    End Sub
End Class

